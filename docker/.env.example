# =============================================================================
# CallScreen Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# Application
CALLSCREEN_ENV=development
CALLSCREEN_SECRET_KEY=change-me-to-a-random-64-char-string
CALLSCREEN_ENCRYPTION_KEY=change-me-to-a-base64-encoded-32-byte-key
CALLSCREEN_ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://callscreen:callscreen@postgres:5432/callscreen
REDIS_URL=redis://redis:6379/0

# Twilio
# Account SID + Auth Token (required — Auth Token is used for webhook signature validation)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# API Key (optional — preferred for REST API calls, falls back to Account SID + Auth Token)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com

# Call Forwarding
# Where approved calls ring. Leave empty to fall back to TWILIO_PHONE_NUMBER.
#
# Scenario A — Ported number + private line:
#   Port your public number to Twilio, forward approved calls to your private number.
#   CALLSCREEN_FORWARD_NUMBER=+1xxxxxxxxxx
#
# Scenario B — SIP / VoIP PBX (UniFi Talk, FreePBX, Asterisk):
#   Forward directly to a SIP endpoint on your LAN or VPN.
#   CALLSCREEN_FORWARD_SIP_URI=sip:100@your-pbx.local
#
# Scenario C — Simultaneous ring (cell + desk + SIP):
#   Ring multiple endpoints at once; first pickup wins.
#   CALLSCREEN_FORWARD_NUMBER=+1xxxxxxxxxx
#   CALLSCREEN_SIMULTANEOUS_RING=+1yyyyyyyyyy,+1zzzzzzzzzz
#
CALLSCREEN_FORWARD_NUMBER=
CALLSCREEN_FORWARD_SIP_URI=
CALLSCREEN_FORWARD_TIMEOUT=30
CALLSCREEN_SIMULTANEOUS_RING=

# AI Providers (via LiteLLM)
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
LITELLM_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# STT (Deepgram)
DEEPGRAM_API_KEY=your_deepgram_key

# TTS (ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_key

# Object Storage (MinIO / S3)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RECORDINGS=callscreen-recordings

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@your-domain.com

# Messaging (optional)
TELEGRAM_BOT_TOKEN=your_telegram_token
DISCORD_BOT_TOKEN=your_discord_token
